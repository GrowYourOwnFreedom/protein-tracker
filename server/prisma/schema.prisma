// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
enum FoodItemType {
  simple
  composite
}

model FoodItem {
  foodItemId String @id @default(uuid())
  name String
  caloriesPer100g Float
  proteinPer100g Float
  foodItemCategoryId String
  type FoodItemType
  userId String
  dateCreated DateTime @default(now())

  foodLogEntries FoodLogEntry[]
}

model Meal {
  mealId String @id @default(uuid())
  name String
  date String
  createdAt DateTime @default(now())
  userId String

  foodLogEntries FoodLogEntry[]
}

model FoodLogEntry  {
  foodLogEntryId String @id @default(uuid())
  foodItemId String
  name String
  weight Float
  calories Float
  protein Float
  date String
  createdAt DateTime @default(now())
  userId String
  mealId String?

  foodItem  FoodItem @relation(fields:[foodItemId], references:[foodItemId])
  meal Meal? @relation(fields:[mealId], references:[mealId])
}

